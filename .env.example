# Tripay Environment Variables
# Copy this file to .env.local and fill in your credentials

# Get these from https://tripay.co.id/member/merchant
TRIPAY_API_KEY=your_api_key_here
TRIPAY_PRIVATE_KEY=your_private_key_here
TRIPAY_MERCHANT_CODE=your_merchant_code_here

# Set to 'sandbox' for testing, 'production' for live
TRIPAY_MODE=sandbox

# Your website's public URL (for return URL after payment)
NEXT_PUBLIC_BASE_URL=https://trinityindonesia.cc

# Callback URL to set in Tripay dashboard:
# https://trinityindonesia.cc/api/callback/tripay

# API endpoints available:
# GET /api/donate - Returns list of donations with nickname and gems
